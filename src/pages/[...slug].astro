---
import { render } from 'astro:content';
import Article from '../layouts/Article.astro';
import { getPublishedPosts, postPath } from '../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts(); // newest first
  return posts.map((post, i) => ({
    // postPath() returns "/slug"; the route param is the slug without the leading slash.
    params: { slug: postPath(post).replace(/^\//, '') },
    props: {
      post,
      // newest-first order → "next" (older) is i+1, "prev" (newer) is i-1
      next: posts[i + 1],
      prev: posts[i - 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---
<Article post={post} prev={prev} next={next}>
  <Content />
</Article>
