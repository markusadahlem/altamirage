---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import EntryRow from "../components/EntryRow.astro";
import {
    getPublishedPosts,
    postPath,
    SECTION_LABEL,
    type Section,
} from "../lib/posts";
import vorlesung from "../assets/vorlesung-tafel.jpg";

const recent = (await getPublishedPosts()).slice(0, 12);
---

<Base title="Altamirage — Markus A. Dahlem" current="start">
    <main>
        <section class="hero wrap">
            <h1>Altamirage</h1>
            <p class="lede">
                Das Glück, ein eigenes <em>Terra&nbsp;incognita</em> zu erschaffen
                – und den ersten Schritt hinein zu wagen.
            </p>
            <p class="hero-aside">
                <a href="/en/">Read this page in English →</a>
            </p>
        </section>

        <section class="block wrap reveal">
            <div class="author">
                <div class="text">
                    <span class="eyebrow">Über mich</span>
                    <h2>Auf der Suche nach Strukturen.</h2>
                    <p>
                        Ich bin <b>Markus A. Dahlem</b>. Anfang der 1990er Jahre
                        kam ich zur Migräneforschung — studiert hatte ich zuvor
                        Physik. Die Physik der Migräne war mein erstes <i
                            >Terra incognita</i
                        >: mit Mathematik nachvollziehen, was im Migränegehirn
                        geschieht, und das in klinisch nutzbares Wissen
                        übersetzen.
                    </p>
                    <p>
                        Anfang der 2000er wollte ich daraus mehr machen als
                        Forschung. Auf einem programmierbaren Nokia-Handy
                        entwickelte ich einen Prototypen und stellte ihn der AOK
                        vor: eine Lösung, die Migräne mit Aura von Vorboten
                        eines Schlaganfalls unterscheiden und Betroffenen
                        unnötige Besuche in der Notaufnahme ersparen sollte. Bis
                        heute ist diese Idee nicht wirklich eingelöst. Der
                        Wunsch, digitale Technologien für die Versorgung nutzbar
                        zu machen, blieb jedoch. 2015 gründete ich ein
                        Unternehmen — zunächst mit einem greifbareren Ansatz:
                        digitaler Verhaltenstherapie für Migräne. Das scheiterte
                        zwar nach weiteren acht Jahren. Doch unsere Migräne-App
                        M-sense wurde über 300.000-mal heruntergeladen und
                        gehörte zu den ersten Apps auf Rezept (DiGA) in
                        Deutschland.
                    </p>
                    <p>
                        Über das US-amerikanische Startup <i
                            >Click Therapeutics</i
                        > kamen Schizophrenie und Depression als neue Anwendungsgebiete
                        digitaler Medizin hinzu, heute ADHS und weiterhin Depression
                        bei MEDICE. Das Hinterland meines <i>Terra incognita</i> heißt
                        nun: pharmakologische und digitale Therapie zusammendenken.
                    </p>
                    <p>
                        Man könnte darin eine Kette von Zufällen sehen. So sehe
                        ich es nicht:
                    </p>
                    <p>
                        <b>Serendipität ist, wenn der Zufall das Leben prägt.</b
                        ><br /><b
                            >Altamirage ist, wenn das Leben den Zufall prägt.</b
                        >
                    </p>
                    <div class="links">
                        <a class="btn" href="/vita">Vita lesen</a>
                        <a
                            class="btn ghost"
                            href="https://www.linkedin.com/in/markusdahlem/"
                            target="_blank"
                            rel="noopener">LinkedIn ↗</a
                        >
                        <a
                            class="btn ghost"
                            href="https://scholar.google.com/citations?hl=en&user=1ioM-GYAAAAJ"
                            target="_blank"
                            rel="noopener">Publikationen ↗</a
                        >
                    </div>
                </div>
                <figure class="figure">
                    <Image
                        src={vorlesung}
                        alt="Markus A. Dahlem an der Tafel mit Formeln zur Physik der Migräne"
                    />
                    <figcaption class="figcap">
                        Vorlesung an der TU Berlin — die Entropie des
                        Kopfschmerzes an der Tafel.
                    </figcaption>
                </figure>
            </div>
        </section>

        <section class="block wrap reveal">
            <div class="section-head">
                <h2>Beiträge</h2>
                <a class="meta" href="/archiv">Alle Beiträge →</a>
            </div>
            <div class="entries">
                {
                    recent.map((post) => (
                        <EntryRow
                            href={postPath(post)}
                            date={String(
                                post.data.pubDate?.getFullYear() ??
                                    post.data.dateLabel ??
                                    "",
                            )}
                            title={post.data.title}
                            desc={post.data.description}
                            sectLabel={
                                SECTION_LABEL[post.data.section as Section]
                            }
                            section={post.data.section}
                            pill={post.data.lang === "en" ? "EN" : undefined}
                        />
                    ))
                }
            </div>
        </section>
    </main>
</Base>

<style>
    .hero-aside {
        margin-top: 1.6rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.03em;
        color: var(--ink-faint);
        max-width: 40ch;
        line-height: 1.7;
    }
    .hero-aside a {
        color: var(--ink-soft);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--rule);
        transition: color 0.2s, text-decoration-color 0.2s;
    }
    .hero-aside a:hover {
        color: var(--ink);
        text-decoration-color: var(--ink);
    }
</style>
