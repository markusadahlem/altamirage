---
// Shared site footer — three-column grid + baseline row, localized chrome.
import { type Locale, footer, homeHref } from '../lib/i18n';
interface Props {
  locale?: Locale;
}
const { locale = 'de' } = Astro.props;
const f = footer[locale];
---
<footer class="foot">
  <div class="wrap">
    <div class="foot-in">
      <div>
        <a class="brand" href={homeHref[locale]}>Altamirage</a>
        <p class="blurb">{f.blurb}</p>
      </div>
      <div>
        <h4>{f.sectionsHeading}</h4>
        {f.sections.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
      <div>
        <h4>{f.moreHeading}</h4>
        {f.more.map((l) => (
          <a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}>{l.label}</a>
        ))}
      </div>
    </div>
    <div class="foot-base">
      <span>© 2009–2026 Markus A. Dahlem · Berlin / New York</span>
      <span>{f.baselineRight}</span>
    </div>
  </div>
</footer>
